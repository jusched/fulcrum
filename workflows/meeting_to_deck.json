    {
      "parameters": {
        "content": "## 6. Production Adapters\\nGoogle Slides and Slack are represented here as the production path after approval. They stay disabled in the committed POC because credentials are not committed.",
        "height": 210,
        "width": 340,
        "color": 2
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130105",
      "name": "Production Adapter Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        2250,
        -280
      ]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "resource": "presentation",
        "operation": "create",
        "title": "={{ $json.meetingTitle || 'Meeting Summary Package' }}",
        "binaryProperty": "data"
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130008",
      "name": "Create Google Slides Presentation",
