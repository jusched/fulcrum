        "operation": "send",
        "channel": "={{ $json.slackChannel || 'leadership-ai' }}",
        "text": "Meeting summary package ready for review. Check the generated artifacts and published slide link."
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130009",
