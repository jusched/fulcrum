    {
      "parameters": {
        "content": "## 7. Error handling\\nErrors surface in explicit branches: missing transcript, build command failure, schema validation failure, or render/deck path failure.\\nEach branch sets a status and reason instead of failing silently.",
        "height": 220,
        "width": 360,
        "color": 1
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130106",
      "name": "Error Handling Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        450,
        210
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": false,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "stderr-mentions-validation",
              "leftValue": "={{ ($json.stderr || '').toLowerCase() }}",
              "rightValue": "validation",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ]
        }
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130021",
