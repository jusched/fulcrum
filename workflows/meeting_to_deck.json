{
  "name": "Meeting Transcript To Deck POC",
  "nodes": [
    {
      "parameters": {
        "content": "## 1. Intake\\nManual trigger runs the repo-safe proof of concept.\\nThe disabled Google Drive trigger shows the production intake path.",
        "height": 170,
        "width": 280,
        "color": 6
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130100",
      "name": "Intake Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -880,
        -220
      ]
    },
    {
      "parameters": {},
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130001",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -860,
        80
      ]
    },
    {
      "parameters": {
        "triggerOn": "specificFolder",
        "folderToWatch": {
          "__rl": true,
          "mode": "id",
          "value": "REPLACE_WITH_GOOGLE_DRIVE_FOLDER_ID"
        },
        "event": "fileCreated",
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "options": {
          "fileType": "all"
        }
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130002",
      "name": "Google Drive Trigger",
      "type": "n8n-nodes-base.googleDriveTrigger",
      "typeVersion": 1,
      "position": [
        -860,
        -20
      ],
      "disabled": true,
      "notes": "Production intake option. Disabled in the repo-safe proof of concept because credentials are not committed."
    },
    {
      "parameters": {
        "content": "## 2. Validation\\nSet runtime config, verify the transcript path exists, and stop early if the intake is invalid.",
        "height": 170,
        "width": 300,
        "color": 3
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130101",
      "name": "Validation Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -610,
        -220
      ]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "runtime-project-root",
              "name": "projectRoot",
              "type": "string",
              "value": "={{ $env.PROJECT_ROOT || '/opt/meeting-to-deck' }}"
            },
            {
              "id": "runtime-transcript",
              "name": "transcriptPath",
              "type": "string",
              "value": "={{ ($env.PROJECT_ROOT || '/opt/meeting-to-deck') + '/inputs/meeting_transcript.txt' }}"
            },
            {
              "id": "runtime-metadata",
              "name": "metadataPath",
              "type": "string",
              "value": "={{ ($env.PROJECT_ROOT || '/opt/meeting-to-deck') + '/inputs/meeting_metadata.json' }}"
            },
            {
              "id": "runtime-output",
              "name": "outputDir",
              "type": "string",
              "value": "={{ ($env.PROJECT_ROOT || '/opt/meeting-to-deck') + '/artifacts/sample_run' }}"
            },
            {
              "id": "runtime-mode",
              "name": "mode",
              "type": "string",
              "value": "sample"
            },
            {
              "id": "runtime-publish",
              "name": "publishToGoogleSlides",
              "type": "boolean",
              "value": false
            },
            {
              "id": "runtime-approve",
              "name": "approveForDistribution",
              "type": "boolean",
              "value": false
            },
            {
              "id": "runtime-title",
              "name": "meetingTitle",
              "type": "string",
              "value": "BrightLane Retail AI Automation Discovery Call"
            },
            {
              "id": "runtime-review",
              "name": "reviewRequired",
              "type": "boolean",
              "value": true
            },
            {
              "id": "runtime-channel",
              "name": "slackChannel",
              "type": "string",
              "value": "leadership-ai"
            }
          ]
        },
        "includeOtherFields": false,
        "options": {}
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130003",
      "name": "Set Runtime Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -600,
        80
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "has-transcript-path",
              "leftValue": "={{ $json.transcriptPath }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ]
        }
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130004",
      "name": "If Transcript Path Exists",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -340,
        80
      ]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "missing-transcript-status",
              "name": "status",
              "type": "string",
              "value": "blocked"
            },
            {
              "id": "missing-transcript-stage",
              "name": "stage",
              "type": "string",
              "value": "intake_validation"
            },
            {
              "id": "missing-transcript-reason",
              "name": "reason",
              "type": "string",
              "value": "Transcript path was empty or not configured."
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130006",
      "name": "Missing Transcript Error",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -60,
        220
      ]
    },
    {
      "parameters": {
        "content": "## 3. Build And Parse\\nRun the local builder, parse the JSON response, and branch explicitly when the package build fails.",
        "height": 180,
        "width": 300,
        "color": 4
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130102",
      "name": "Build Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -100,
        -220
      ]
    },
    {
      "parameters": {
        "command": "python -m execution.build_sample_package --transcript \"{{$json.transcriptPath}}\" --metadata \"{{$json.metadataPath}}\" --output-dir \"{{$json.outputDir}}\" --mode \"{{$json.mode}}\""
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130005",
      "name": "Build Sample Package",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -60,
        20
      ],
      "continueOnFail": true,
      "notes": "Calls the local Python package builder used by the repo proof of concept."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "command-succeeded",
              "leftValue": "={{ $json.exitCode }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130012",
      "name": "Build Command Succeeded?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        190,
        20
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const first = items[0].json;\nconst raw = first.stdout || first.data || first.response || '';\nconst parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\nreturn [{ json: { ...parsed, commandExitCode: first.exitCode ?? 0, stderr: first.stderr || '' } }];"
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130013",
      "name": "Parse Builder Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        -40
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "validation-passed",
              "leftValue": "={{ $json.validation.valid }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ]
        }
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130014",
      "name": "Validation Passed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        700,
        -40
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "presentation-path-present",
              "leftValue": "={{ $json.artifacts.presentation }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty",
                "singleValue": true
              }
            }
          ]
        }
      },
      "id": "af5d0f76-7e1b-4ec0-b54e-86be7f130015",
      "name": "Presentation Path Present?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        960,
        -40
      ]
    },
    {
      "parameters": {
        "content": "## 4. Intermediate outputs\\nThis step surfaces the JSON payload, validation report, markdown summary, and final PPTX so the reviewer can inspect intermediate and final artifacts.",
